RewriteEngine On

# 1. Map the root request to dist/index.html
RewriteRule ^$ dist/index.html [L]

# 2. If a requested file or directory does not exist in the root,
# transparently look for it inside the dist/ folder
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ dist/$1 [L]
